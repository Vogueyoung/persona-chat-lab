# Copy this to .env and fill in real values.
# The app runs without OPENAI_API_KEY — it falls back to a deterministic Dummy service.

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Paths are relative to project root.
CHARACTERS_DIR=characters
LORE_DIR=data/lore
FAISS_DIR=data/faiss

# RAG switch. Set to true only after building the FAISS index.
RAG_ENABLED=false

# Response tuning defaults (can be overridden per character).
DEFAULT_TEMPERATURE=0.8
DEFAULT_MAX_TOKENS=600
